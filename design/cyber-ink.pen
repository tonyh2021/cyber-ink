                    {
                      "type": "frame",
                      "id": "J1KhkG",
                      "name": "WritingCanvas",
                      "width": "fill_container",
                      "height": "fill_container",
                      "fill": "$surface-canvas",
                      "layout": "vertical",
                      "gap": 16,
